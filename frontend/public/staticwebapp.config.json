{
  "routes": [
    { "route": "/", "redirect": "/vi", "statusCode": 301 },
    { "route": "/vi", "rewrite": "/vi/index.html" },
    { "route": "/vi/tinh-nang", "rewrite": "/vi/tinh-nang/index.html" },
    { "route": "/vi/cach-hoat-dong", "rewrite": "/vi/cach-hoat-dong/index.html" },
    { "route": "/en", "rewrite": "/en/index.html" },
    { "route": "/en/features", "rewrite": "/en/features/index.html" },
    { "route": "/en/how-it-works", "rewrite": "/en/how-it-works/index.html" },
    { "route": "/login", "rewrite": "/index.html", "headers": { "X-Robots-Tag": "noindex, nofollow" } },
    { "route": "/signup", "rewrite": "/index.html", "headers": { "X-Robots-Tag": "noindex, nofollow" } },
    { "route": "/dashboard", "rewrite": "/index.html", "headers": { "X-Robots-Tag": "noindex, nofollow" } },
    { "route": "/trips/*", "rewrite": "/index.html", "headers": { "X-Robots-Tag": "noindex, nofollow" } },
    { "route": "/share/*", "rewrite": "/index.html", "headers": { "X-Robots-Tag": "noindex, nofollow" } },
    { "route": "/blogs/*", "rewrite": "/index.html", "headers": { "X-Robots-Tag": "noindex, nofollow" } }
  ],
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": ["/api/*", "/assets/*", "/*.{css,js,map,png,svg,ico,txt,woff,woff2}"]
  }
}
